/* ============ 变量 ============ */
page {
  --bg-primary: #000000;
  --bg-secondary: #1c1c1e;
  --bg-tertiary: #2c2c2e;
  --text-primary: #ffffff;
  --text-secondary: #aeaeb2;
  --text-tertiary: #636366;
  --blue: #0a84ff;
  --blue-light: #64d2ff;
  --teal: #64d2ff;
  --purple: #bf5af2;
  --red: #ff375f;
  --green: #30d158;
  --orange: #ff9f0a;
  --separator: rgba(255, 255, 255, 0.08);
  --fill-primary: rgba(10, 132, 255, 0.12);
  --fill-secondary: rgba(255, 255, 255, 0.04);
  --fill-tertiary: rgba(255, 255, 255, 0.06);
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
}

/* ============ 容器 ============ */
.app-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
}

/* ============ 头部 ============ */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 24rpx 12rpx;
  border-bottom: 1rpx solid var(--separator);
  background: rgba(0, 0, 0, 0.9);
}

.logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.logo-emoji { font-size: 44rpx; }
.logo-title {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.nav-tabs {
  display: flex;
  gap: 8rpx;
  background: var(--fill-secondary);
  border-radius: 16rpx;
  padding: 6rpx;
}

.nav-tab {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  border-radius: 12rpx;
  transition: all 0.2s;
}

.nav-tab.active {
  background: var(--blue);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.3);
}

/* ============ 面板 ============ */
.tab-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

/* ============ 和弦查询 ============ */
.chord-mode-tabs {
  display: flex;
  gap: 6rpx;
  margin-bottom: 16rpx;
  background: var(--fill-secondary);
  border-radius: 14rpx;
  padding: 6rpx;
}

.chord-mode-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  border-radius: 10rpx;
  transition: all 0.2s;
}

.chord-mode-tab.active {
  background: var(--fill-primary);
  color: var(--blue-light);
}

/* 选择器 */
.chord-selector { margin-bottom: 16rpx; }
.select-group { margin-bottom: 12rpx; }
.select-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
}

.note-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.note-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  background: var(--fill-tertiary);
  color: var(--text-secondary);
  transition: all 0.2s;
}

.note-btn.active {
  background: var(--blue);
  color: #fff;
}

.chord-type-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.type-btn {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  background: var(--fill-tertiary);
  color: var(--text-tertiary);
  transition: all 0.2s;
}

.type-btn.active {
  background: var(--fill-primary);
  color: var(--blue-light);
  border: 1rpx solid var(--blue);
}

.scale-type-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.scale-type-btn {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 20rpx;
  background: var(--fill-tertiary);
  color: var(--text-tertiary);
  transition: all 0.2s;
}

.scale-type-btn.active {
  background: var(--teal);
  color: #000;
}

/* 和弦名称 */
.chord-name-display {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 4rpx;
}

.chord-type-badge {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--blue-light);
  background: var(--fill-primary);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  margin-left: 12rpx;
  vertical-align: middle;
}

.reverse-chord-hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
}

/* 指板 */
.chord-diagram-scroll-container { margin: 12rpx 0 4rpx; }
.fretboard-scroll { white-space: nowrap; }
.chord-diagram-container {
  display: flex;
  justify-content: center;
  align-items: center;
}

.chord-canvas {
  width: 680rpx;
  height: 600rpx;
}

.strum-hint {
  text-align: center;
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
}

/* 指型导航 */
.voicing-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.voicing-arrow {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--fill-tertiary);
  font-size: 24rpx;
  color: var(--blue-light);
  font-weight: 700;
  transition: all 0.2s;
}

.voicing-arrow.disabled {
  opacity: 0.3;
  color: var(--text-tertiary);
}

.voicing-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  min-width: 160rpx;
  text-align: center;
}

.fav-btn {
  font-size: 36rpx;
  padding: 0 12rpx;
}

.fav-active { color: var(--red); }
.fav-inactive { color: var(--text-tertiary); }

/* 音符标签 */
.chord-note-tags {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.chord-note-tag {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  color: #fff;
}

.chord-note-tag.root { background: var(--red); }
.chord-note-tag.third { background: var(--blue); }
.chord-note-tag.fifth { background: var(--purple); }
.chord-note-tag.seventh { background: var(--orange); }
.chord-note-tag.ninth { background: var(--teal); }
.chord-note-tag.eleventh { background: var(--green); }

/* 和弦信息卡 */
.chord-info {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.chord-info-card {
  flex: 1;
  background: var(--fill-tertiary);
  border-radius: 16rpx;
  padding: 16rpx;
  text-align: center;
}

.info-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 收藏列表 */
.fav-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.fav-empty {
  font-size: 22rpx;
  color: var(--text-tertiary);
  width: 100%;
  text-align: center;
  padding: 12rpx;
}

.fav-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: var(--fill-tertiary);
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.fav-remove {
  color: var(--red);
  font-size: 28rpx;
  font-weight: 700;
}

/* 和弦进行 */
.prog-toggle {
  padding: 16rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--blue-light);
  background: var(--fill-secondary);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.prog-panel {
  background: var(--fill-secondary);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.prog-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
  min-height: 40rpx;
}

.prog-empty {
  font-size: 22rpx;
  color: var(--text-tertiary);
  width: 100%;
  text-align: center;
}

.prog-chip {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: var(--fill-tertiary);
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.prog-chip.active {
  background: var(--blue);
  color: #fff;
}

.prog-remove {
  color: var(--red);
  font-size: 24rpx;
  font-weight: 700;
  margin-left: 4rpx;
}

.prog-controls {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.prog-add-btn {
  padding: 10rpx 20rpx;
  background: var(--fill-primary);
  color: var(--blue-light);
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.prog-play-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--blue);
  border-radius: 50%;
  font-size: 24rpx;
  color: #fff;
}

.prog-play-btn.running { background: var(--red); }

.prog-bpm {
  flex: 1;
  min-width: 120rpx;
}

.prog-bpm slider { width: 100%; }

.prog-bpm-val {
  font-size: 20rpx;
  color: var(--text-tertiary);
  font-weight: 600;
}

.prog-clear-btn {
  padding: 10rpx 20rpx;
  background: transparent;
  color: var(--red);
  border: 1rpx solid var(--red);
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* ============ 调音器 ============ */
.tuner-panel { align-items: center; }

.tuner-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.tuner-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.tuner-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.instrument-selector {
  display: flex;
  gap: 8rpx;
  margin-bottom: 24rpx;
  background: var(--fill-secondary);
  border-radius: 16rpx;
  padding: 6rpx;
}

.instrument-btn {
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  color: var(--text-tertiary);
  transition: all 0.2s;
}

.instrument-btn.active {
  background: var(--fill-primary);
  color: var(--blue-light);
}

/* 琴头 */
.headstock-container {
  width: 100%;
  background: linear-gradient(180deg, rgba(44, 44, 46, 0.6), rgba(28, 28, 30, 0.8));
  border-radius: 24rpx;
  border: 1rpx solid var(--separator);
  padding: 32rpx 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.headstock-body {
  display: flex;
  align-items: stretch;
  gap: 8rpx;
}

.headstock-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.headstock-string {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 12rpx;
  background: var(--fill-tertiary);
  border-radius: 12rpx;
  transition: all 0.2s;
}

.headstock-left .headstock-string { flex-direction: row; }
.headstock-right .headstock-string { flex-direction: row-reverse; }

.string-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.headstock-left .string-info { flex-direction: row; }
.headstock-right .string-info-right { flex-direction: row-reverse; }

.string-number {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 700;
  min-width: 36rpx;
  text-align: center;
}

.string-note-display {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  min-width: 40rpx;
  text-align: center;
}

.tuner-meter-horizontal {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 80rpx;
}

.tuner-bar-track {
  width: 100%;
  height: 8rpx;
  background: var(--fill-tertiary);
  border-radius: 4rpx;
  overflow: hidden;
  position: relative;
}

.tuner-fill {
  height: 100%;
  width: 50%;
  background: var(--blue);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.tuner-labels {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: var(--text-tertiary);
}

.center-label { font-weight: 700; }

.string-play-btn {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  background: var(--fill-primary);
  color: var(--blue-light);
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
}

/* 琴颈 */
.headstock-neck {
  width: 6rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.neck-line {
  flex: 1;
  width: 4rpx;
  background: rgba(255, 255, 255, 0.08);
}

.neck-nut {
  width: 24rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 4rpx;
}

.headstock-hint {
  text-align: center;
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 20rpx;
}

.hint-bold { color: var(--text-secondary); font-weight: 600; }

/* 麦克风 */
.tuner-mic-section {
  width: 100%;
  padding: 40rpx;
  background: var(--fill-secondary);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.mic-btn {
  padding: 24rpx 64rpx;
  background: var(--blue);
  color: #fff;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 700;
  transition: all 0.2s;
}

.mic-btn.listening {
  background: var(--red);
}

.detected-freq {
  font-size: 36rpx;
  font-weight: 300;
  color: var(--text-secondary);
  font-family: "SF Pro Display", -apple-system, sans-serif;
}

.detected-note {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--green);
}

/* ============ 节拍器 ============ */
.metronome-panel {
  align-items: center;
  justify-content: center;
}

.metronome-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.bpm-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.bpm-value {
  font-size: 160rpx;
  font-weight: 200;
  background: linear-gradient(180deg, var(--text-primary), var(--teal));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  font-family: "SF Pro Display", -apple-system, sans-serif;
  letter-spacing: -6rpx;
}

.bpm-label {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 600;
}

.time-signature-selector {
  display: flex;
  gap: 8rpx;
}

.ts-btn {
  padding: 12rpx 28rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  background: var(--fill-secondary);
  color: var(--text-tertiary);
  border: 1rpx solid var(--separator);
  transition: all 0.2s;
}

.ts-btn.active {
  background: var(--teal);
  color: #000;
  border-color: var(--teal);
}

.bpm-control {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  margin-bottom: 20rpx;
}

.bpm-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--fill-tertiary);
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
  transition: all 0.1s;
}

.bpm-btn:active {
  background: var(--fill-primary);
  color: var(--blue-light);
}

.bpm-slider {
  flex: 1;
  margin: 0 8rpx;
}

.tap-tempo {
  margin-bottom: 28rpx;
}

.tap-btn {
  padding: 18rpx 48rpx;
  background: var(--fill-tertiary);
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  text-align: center;
}

.beat-visual {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.beat-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--fill-secondary);
  transition: all 0.15s;
}

.beat-dot.active {
  background: var(--blue);
  box-shadow: 0 0 32rpx rgba(10, 132, 255, 0.5);
  transform: scale(1.25);
}

.beat-dot.accent {
  background: var(--purple);
  box-shadow: 0 0 40rpx rgba(191, 90, 242, 0.5);
  transform: scale(1.4);
}

.metronome-controls {
  margin-bottom: 28rpx;
}

.metronome-start-btn {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--blue);
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(10, 132, 255, 0.3);
}

.metronome-start-btn.running {
  background: var(--red);
  box-shadow: 0 8rpx 32rpx rgba(255, 55, 95, 0.3);
}

.sound-select {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.picker-display {
  padding: 12rpx 32rpx;
  background: var(--fill-tertiary);
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  border: 1rpx solid var(--separator);
}
